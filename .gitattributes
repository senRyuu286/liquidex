# Set default behavior to automatically normalize line endings
* text=auto

# Enforce LF line endings for all source code files
*.dart text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.gradle text eol=lf
*.xml text eol=lf
*.plist text eol=lf
*.xcconfig text eol=lf

# Explicit binary files to prevent corruption from line ending adjustments
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary

# Tell GitHub/GitLab to treat built/generated files as boilerplate 
# This collapses them by default in pull requests so reviews stay focused on handwritten code.
*.g.dart linguist-generated=true
*.freezed.dart linguist-generated=true

# Ensure locking mechanics don't cause cross-platform diff problems
Podfile.lock text eol=lf
pubspec.lock text eol=lf